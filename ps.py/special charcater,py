# count the digita and special characters in a string
a=(input("Enter a text : "))
numbers=0
specialsymbols=0
lower=0
upper=0
for i in a:
    if(ord(i)>=48 and ord(i)<=57):
        numbers=numbers+1
    elif(ord(i)>=97 and ord(i)<=122):
        lower=lower+1
    elif(ord(i)>=65 and ord(i)<= 90):
        upper=upper+1
    elif(ord(i)!=32):
        specialsymbols=specialsymbols+1
print("DIGITS: ",numbers)
print("SPECIAL SYMBOLS: ",specialsymbols)
print("LOWER:",lower)
print("UPPER:",upper)

